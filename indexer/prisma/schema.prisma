generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Transaction {
  id               String   @id @default(cuid())
  signature        String   @unique
  slot             BigInt
  blockTime        DateTime?
  success          Boolean
  fee              BigInt?
  computeUnitsUsed BigInt?
  accounts         String[] // All account pubkeys involved
  instructions     Json[]   // Array of instruction data
  memos            Memo[]
  accountTransactions AccountTransaction[]
  accountBalances  AccountBalance[]
  createdAt        DateTime @default(now())
  
  @@index([slot])
  @@index([success])
  @@index([blockTime])
}

model Memo {
  id            String      @id @default(cuid())
  content       String
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  
  @@index([content])
}

model FailedTransaction {
  id          String   @id @default(cuid())
  signature   String   @unique
  slot        BigInt
  error       String
  errorCode   String?
  logs        String[] // Array of log messages
  accounts    String[] // Involved accounts
  blockTime   DateTime?
  createdAt   DateTime @default(now())
  
  @@index([error])
  @@index([errorCode])
}

model Account {
  id        String   @id @default(cuid())
  address   String   @unique
  firstSeen DateTime @default(now())
  lastSeen  DateTime @updatedAt
  accountTransactions AccountTransaction[]

  @@index([address])
}

model AccountTransaction {
  id            String      @id @default(cuid())
  accountId     String
  transactionId String
  account       Account     @relation(fields: [accountId], references: [id])
  transaction   Transaction @relation(fields: [transactionId], references: [id])

  @@unique([accountId, transactionId])
  @@index([accountId])
  @@index([transactionId])
}

model AccountBalance {
  id              String      @id @default(cuid())
  accountAddress  String
  transactionId   String
  transaction     Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  accountIndex    Int
  preBalance      BigInt
  postBalance     BigInt
  balanceChange   BigInt
  slot            BigInt
  blockTime       DateTime?
  
  @@index([accountAddress])
  @@index([accountAddress, slot])
  @@index([transactionId])
  @@unique([transactionId, accountIndex])
}

